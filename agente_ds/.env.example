# Agente DS — Configuração de Ambiente
# Copie para .env e preencha com seus valores

# ═══════════════════════════════════════════
# LLM — Google Gemini (TEXT ONLY)
# ═══════════════════════════════════════════
# Obtenha em: https://aistudio.google.com/api-keys
GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash-lite
GEMINI_TIER=gemini_free

# ═══════════════════════════════════════════
# LLM — OpenAI (Alternativo)
# ═══════════════════════════════════════════
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIER=openai_tier1

# ═══════════════════════════════════════════
# LLM — Provider Preference
# ═══════════════════════════════════════════
# auto = tenta Gemini primeiro, OpenAI como fallback
# gemini = força Gemini
# openai = força OpenAI
LLM_PROVIDER=auto

# ═══════════════════════════════════════════
# Servidor
# ═══════════════════════════════════════════
SERVER_HOST=0.0.0.0
SERVER_PORT=8006
DEBUG=false

# ═══════════════════════════════════════════
# Acervo DS — Paths (relativos à raiz Materiais_DS)
# ═══════════════════════════════════════════
ACERVO_ROOT=..
CATALOG_PATH=../catalog.json
TAXONOMY_PATH=../taxonomy.json

# ═══════════════════════════════════════════
# Prática
# ═══════════════════════════════════════════
PRATICA=DS
PRATICA_NOME=Desenvolvimento de Soluções

# ═══════════════════════════════════════════
# Trace
# ═══════════════════════════════════════════
TRACE_ENABLED=true
